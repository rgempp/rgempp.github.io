logLikAndrich <- function(par, n, r) {
g   <- nrow(n)
mu  <- c(par[1:(g-1)], 0)
delta <- par[g:(g+r-1)]
kappa <- -cumsum(c(0, delta))   # κ_0=0, κ_x=-sum_{k=1..x}δ_k
phi   <- 0:r
logL  <- 0
for(i in 1:g) {
eta <- kappa + phi*mu[i]
pr  <- exp(eta - log(sum(exp(eta))))
logL <- logL + sum(n[i,] * log(pr))
}
-logL
}
