################
rasch_from_acat <- function(fit,
ref_newdata,
newdata = NULL,
center = FALSE) {
# fit:   objeto de vglm con family = acat(parallel = TRUE, ...)
# ref_newdata: data.frame con UNA fila que define el grupo/patrón de covariables de referencia
#              donde fijaremos mu_ref = 0.
# newdata: data.frame con las combinaciones de covariables donde queremos obtener mu_g.
#          Si es NULL, usamos ref_newdata.
# center: si TRUE, se centra la escala restando la media de tau a mu y tau.
# --- 1. Detectar si el modelo está "reverseado" ---
# Para acat(), VGAM guarda la info en fit@family@misc$reverse
reverse <- FALSE
if (!is.null(fit@family@misc$reverse)) {
reverse <- isTRUE(fit@family@misc$reverse)
}
# --- 2. Si newdata es NULL, usamos ref_newdata ---
if (is.null(newdata)) {
newdata <- ref_newdata
}
# --- 3. Obtener los etas (logits adyacentes) para la fila de referencia ---
# predict(..., type = "link") devuelve una matriz:
#   filas = obs, columnas = pasos (categorías-1).
eta_ref <- predict(fit, newdata = ref_newdata, type = "link")
eta_ref <- as.numeric(eta_ref)  # vector de longitud = #pasos
# Si el modelo se ajustó con reverse = TRUE, cambiamos el signo
# porque queremos log(pi_{j+1}/pi_j).
if (reverse) {
eta_ref <- -eta_ref
}
# --- 4. Umbrales tau_k (asumimos mu_ref = 0) ---
# En la parametrización Rasch/Andrich:
#   eta_j(ref) = mu_ref - tau_{j+1},  y definimos mu_ref = 0
#   => tau_{j+1} = -eta_j(ref)
tau <- -eta_ref
names(tau) <- paste0("tau_", seq_along(tau) + 1)
# --- 5. Obtener etas para todos los patrones en newdata ---
eta_all <- predict(fit, newdata = newdata, type = "link")
if (reverse) {
eta_all <- -eta_all
}
# --- 6. Localizaciones mu_g ---
# Para cualquier patrón g:
#   eta_j(g) = mu_g - tau_{j+1}  =>  mu_g = eta_j(g) + tau_{j+1}.
# En teoría, todos los j dan el mismo mu_g (por parallel = TRUE);
# por estabilidad numérica promediamos sobre j.
mu_mat <- sweep(eta_all, 2, tau, "+")  # suma tau por columna
mu_vec <- rowMeans(mu_mat)
# Armamos data.frame con mu_g y las covariables de newdata
mu_df <- cbind(newdata, mu = as.numeric(mu_vec))
# --- 7. Opcional: centrar la escala ---
if (center) {
shift <- mean(tau)
tau <- tau - shift
mu_df$mu <- mu_df$mu - shift
}
# --- 8. Resultado ---
list(
mu  = mu_df,
tau = tau
)
}
########### Ejemplo completo
library(VGAM)
# Datos del ejemplo
tonsils <- data.frame(
carrier = factor(c(0, 1)),   # 0 = no carrier, 1 = carrier
y1      = c(497, 19),
y2      = c(560, 29),
y3      = c(269, 24)
)
# Ajuste del modelo de categorías adyacentes con pendiente paralela
fit_acat <- vglm(
cbind(y1, y2, y3) ~ carrier,
family = acat(parallel = TRUE, reverse = FALSE),
data   = tonsils
)
summary(fit_acat)
# Elegimos como referencia el grupo "no carrier" (carrier = 0)
ref_newdata <- data.frame(carrier = factor(0, levels = levels(tonsils$carrier)))
# Y queremos mu_g para ambos grupos (unique patrones de carrier)
newdata <- data.frame(carrier = factor(c(0, 1), levels = levels(tonsils$carrier)))
rasch_par <- rasch_from_acat(
fit        = fit_acat,
ref_newdata = ref_newdata,
newdata     = newdata,
center      = FALSE  # o TRUE si quieres centrar la escala
)
rasch_par$mu   # mu_g por grupo (con covariables)
rasch_par$tau  # umbrales tau_k
################
rasch_from_acat <- function(fit,
ref_newdata,
newdata = NULL,
center = FALSE,
reverse = FALSE) {
# fit:   objeto de vglm con family = acat(parallel = TRUE, ...)
# ref_newdata: data.frame con UNA fila que define el grupo/patrón de covariables
#              de referencia, donde fijamos mu_ref = 0.
# newdata: data.frame con las combinaciones de covariables donde queremos mu_g.
#          Si es NULL, usa ref_newdata.
# center: si TRUE, centra escala restando la media de tau a mu y tau.
# reverse: pon TRUE si ajustaste acat(..., reverse = TRUE),
#          FALSE si fue reverse = FALSE (o no especificaste y usaste default).
# --- 1. newdata por defecto ---
if (is.null(newdata)) {
newdata <- ref_newdata
}
# --- 2. etas (logits adyacentes) para la fila de referencia ---
eta_ref <- predict(fit, newdata = ref_newdata, type = "link")
eta_ref <- as.numeric(eta_ref)  # vector de longitud = # pasos
# Si el modelo se ajustó con reverse = TRUE,
# queremos log(pi_{j+1}/pi_j), así que cambiamos el signo
if (reverse) {
eta_ref <- -eta_ref
}
# --- 3. Umbrales tau_k (suponiendo mu_ref = 0) ---
# En la parametrización Rasch/Andrich:
#   eta_j(ref) = mu_ref - tau_{j+1}, y mu_ref = 0
#   => tau_{j+1} = - eta_j(ref)
tau <- -eta_ref
names(tau) <- paste0("tau_", seq_along(tau) + 1)
# --- 4. etas para todos los patrones en newdata ---
eta_all <- predict(fit, newdata = newdata, type = "link")
if (reverse) {
eta_all <- -eta_all
}
# --- 5. Localizaciones mu_g ---
# eta_j(g) = mu_g - tau_{j+1}  =>  mu_g = eta_j(g) + tau_{j+1}.
# Como parallel = TRUE, todos los j dan el mismo mu_g (en teoría);
# por estabilidad numérica promediamos sobre j.
mu_mat <- sweep(eta_all, 2, tau, "+")  # suma tau por columna
mu_vec <- rowMeans(mu_mat)
# Armamos data.frame con mu_g y las covariables de newdata
mu_df <- cbind(newdata, mu = as.numeric(mu_vec))
# --- 6. Opcional: centrar la escala ---
if (center) {
shift <- mean(tau)
tau <- tau - shift
mu_df$mu <- mu_df$mu - shift
}
# --- 7. Resultado ---
list(
mu  = mu_df,
tau = tau
)
}
########### Ejemplo completo
library(VGAM)
tonsils <- data.frame(
carrier = factor(c(0, 1)),   # 0 = no carrier, 1 = carrier
y1      = c(497, 19),
y2      = c(560, 29),
y3      = c(269, 24)
)
fit_acat <- vglm(
cbind(y1, y2, y3) ~ carrier,
family = acat(parallel = TRUE, reverse = FALSE),
data   = tonsils
)
summary(fit_acat)
deviance(fit_acat); df.residual(fit_acat)
# Fila de referencia: no carriers
ref_newdata <- data.frame(
carrier = factor(0, levels = levels(tonsils$carrier))
)
# Queremos mu_g para ambos grupos
newdata <- data.frame(
carrier = factor(c(0, 1), levels = levels(tonsils$carrier))
)
rasch_par <- rasch_from_acat(
fit         = fit_acat,
ref_newdata = ref_newdata,
newdata     = newdata,
center      = FALSE,   # o TRUE si quieres centrar la escala
reverse     = FALSE    # porque usamos acat(..., reverse = FALSE)
)
rasch_par$mu    # localizaciones de los grupos
rasch_par$tau   # umbrales de categoría
