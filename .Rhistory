library(numDeriv)
logLikAndrich <- function(par, n, r) {
g   <- nrow(n)
mu  <- c(par[1:(g-1)], 0)          # último grupo = 0
delta <- par[g:(g+r-1)]
kappa <- -cumsum(c(0, delta))      # κ_0=0, κ_x=-sum δ_k
phi   <- 0:r
logL  <- 0
for(i in 1:g) {
eta <- kappa + phi*mu[i]
pr  <- exp(eta - log(sum(exp(eta))))
logL <- logL + sum(n[i,] * log(pr))
}
-logL
}
g <- nrow(tabla); r <- ncol(tabla) - 1
init <- c(rep(0, g-1), 1:r)  # mu=0, δ=1,2
opt <- optim(par = init,
fn  = logLikAndrich,
n   = tabla,
r   = r,
method = "BFGS")
# Errores estándar
H <- hessian(logLikAndrich, opt$par, n = tabla, r = r)
se <- sqrt(diag(solve(H)))
# Errores estándar
H <- hessian(logLikAndrich, opt$par, n = tabla, r = r)
se <- sqrt(diag(solve(H)))
res <- data.frame(
grupo = rownames(tabla),
mu_hat = c(opt$par[1:(g-1)], 0),
delta1 = opt$par[g],
delta2 = opt$par[g+1],
se_d1  = se[g],
se_d2  = se[g+1]
)
print(res)
# Predicciones bajo modelo tricotómico
pred <- matrix(0, nrow(tabla), 3)
for(i in 1:g) {
eta <- c(0, -opt$par[g], -opt$par[g]-opt$par[g+1]) + (0:2)*opt$par[i]
pr  <- exp(eta - log(sum(exp(eta))))
pred[i,] <- pr * sum(tabla[i,])
}
# Chi²
chi2 <- sum((tabla - pred)^2 / pred)
c("Chi²" = chi2, "gl" = (g-1)*(r), "p" = pchisq(chi2, (g-1)*(r), lower.tail = FALSE))
