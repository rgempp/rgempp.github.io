tabla <- matrix(c(19, 29, 24,
497, 560, 269), nrow = 2, byrow = TRUE)
colnames(tabla) <- c("Cat0","Cat1","Cat2")
rownames(tabla) <- c("Carrier","NoCar")
logLikAndrich <- function(par, n, r) {
# par = c(mu_1,...,mu_{g-1}, delta_1,...,delta_r)
g   <- nrow(n)
mu  <- c(par[1:(g-1)], 0)          # último grupo pivote = 0
delta <- par[g:(g+r-1)]
kappa <- -cumsum(delta)            # κ_0=0, κ_x=-sum_{k=1..x}δ_k
phi   <- 0:r                       # φ_x = x
logL  <- 0
for(i in 1:g) {
eta <- kappa + phi*mu[i]         # vector length r+1
pr  <- exp(eta - log(sum(exp(eta))))
logL <- logL + sum(n[i,] * log(pr))
}
-logL                             # optim minimiza
}
# Estimaciones
mu_hat     <- c(opt$par[1:(g-1)], 0)
# Estimaciones
mu_hat     <- c(opt$par[1:(g-1)], 0)
delta_hat  <- opt$par[g:(g+r-1)]
se_delta   <- sqrt(diag(solve(opt$hessian)))[g:(g+r-1)]
data.frame(grupo   = rownames(tabla),
mu_hat  = mu_hat,
delta   = delta_hat,
se_delta = se_delta)
g <- nrow(tabla); r <- ncol(tabla) - 1
init <- c(rep(0, g-1), 1:r)        # mu=0, δ=1,2,...
opt  <- optim(par = init,
fn  = logLikAndrich,
n   = tabla,
r   = r,
method = "BFGS",
hessian = TRUE)
# Estimaciones
mu_hat     <- c(opt$par[1:(g-1)], 0)
delta_hat  <- opt$par[g:(g+r-1)]
se_delta   <- sqrt(diag(solve(opt$hessian)))[g:(g+r-1)]
data.frame(grupo   = rownames(tabla),
mu_hat  = mu_hat,
delta   = delta_hat,
se_delta = se_delta)
